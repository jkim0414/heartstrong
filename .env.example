# Copy to .env.local for local dev (`vercel dev`), AND set these in your
# Vercel / Netlify project's Environment Variables for production.
#
# Do NOT commit real values. Do NOT paste them into chat.

# --- AI workout generation (serverless function only; never sent to the client) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Accounts + cloud sync (Supabase) ---
# From your Supabase project: Settings → API.
# The VITE_* pair is the public anon key (safe in the browser; Row-Level
# Security protects the data). The function also uses them to verify sessions.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: if your serverless host doesn't expose VITE_* vars to functions,
# also set these (same values) so /api/generate can verify sign-ins.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
